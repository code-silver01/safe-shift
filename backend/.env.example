# Server
PORT=3001

# MongoDB (local instance)
MONGODB_URI=mongodb://localhost:27017/safeshift

# AWS Bedrock
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# GitHub (optional - for higher rate limits on public repos)
GITHUB_TOKEN=

# Workspace (temp directory for cloned repos)
WORKSPACE_DIR=./workspace
